local xrayActive = false
local xrayOriginals = {}

local function startXRay()
    xrayActive = true
    xrayOriginals = {}
    local char = player.Character
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local isLocalChar = char and obj:IsDescendantOf(char)
            local isPlayerChar = false
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character and obj:IsDescendantOf(p.Character) then
                    isPlayerChar = true; break
                end
            end
            if not isLocalChar and not isPlayerChar then
                table.insert(xrayOriginals, {part=obj, trans=obj.Transparency, cast=obj.CastShadow})
                -- Transparence lÃ©gÃ¨re : 0.5 pour garder le contexte visuel (pas trop sombre)
                obj.Transparency = math.max(obj.Transparency, 0.5)
                obj.CastShadow = false
            end
        end
    end
    -- Highlight nÃ©on visible sur les ennemis (visible mÃªme Ã  travers les murs)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local h = Instance.new("Highlight")
            h.Name = "XRayHighlight"
            h.Adornee = p.Character
            h.FillColor = Color3.fromRGB(255, 60, 60)
            h.OutlineColor = Color3.fromRGB(255, 255, 255)
            h.FillTransparency = 0.3
            h.OutlineTransparency = 0
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop  -- visible Ã  travers les murs
            h.Parent = Lib
        end
    end
end

local function stopXRay()
    xrayActive = false
    for _, data in ipairs(xrayOriginals) do
        if data.part and data.part.Parent then
            data.part.Transparency = data.trans
            data.part.CastShadow = data.cast
        end
    end
    xrayOriginals = {}
    for _, obj in ipairs(Lib:GetChildren()) do
        if obj.Name == "XRayHighlight" then obj:Destroy() end
    end
end

