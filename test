    local row = Instance.new("Frame", panel)
    row.Size = UDim2.new(1, -14, 0, 34)
    row.Position = UDim2.new(0, 7, 0, 28)
    row.BackgroundTransparency = 1

    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(1, -50, 0, 6)
    track.Position = UDim2.new(0, 0, 0.5, -3)
    track.BackgroundColor3 = Color3.fromRGB(20, 30, 50)
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(defaultVal / 100, 0, 1, 0)
    fill.BackgroundColor3 = C_ACCENT; fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("TextButton", track)
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(defaultVal / 100, -7, 0.5, -7)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Text = ""; knob.AutoButtonColor = false; knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local valLbl = Instance.new("TextLabel", row)
    valLbl.Size = UDim2.new(0, 38, 1, 0)
    valLbl.Position = UDim2.new(1, -38, 0, 0)
    valLbl.BackgroundTransparency = 1
