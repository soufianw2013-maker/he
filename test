    valLbl.TextColor3 = C_ACCENT
    valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 13

    local dragging = false
    local function updateSlider(inputPos)
        local ap = track.AbsolutePosition
        local as = track.AbsoluteSize
        local rel = math.clamp((inputPos.X - ap.X) / as.X, 0, 1)
        local spd = math.max(5, math.floor(rel * 100))
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -7, 0.5, -7)
        valLbl.Text = tostring(spd)
        onChanged(spd)
    end
    knob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then dragging = true end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement
        or i.UserInputType == Enum.UserInputType.Touch) then updateSlider(i.Position) end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then updateSlider(i.Position) end
    end)
    return panel
end

